{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openbioforge.example/schemas/candidate_term.schema.json",
  "title": "CandidateTerm",
  "type": "object",
  "required": ["candidate_label", "confidence_score", "evidence"],
  "properties": {
    "candidate_label": { "type": "string" },
    "term_type": { "type": "string", "enum": ["class", "relation", "individual", "annotation_candidate"] },
    "proposed_definition": { "type": ["string", "null"] },
    "synonyms": { "type": "array", "items": { "type": "string" } },
    "proposed_parent_term": { "type": ["string", "null"] },
    "confidence_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "uncertainty_note": { "type": ["string", "null"] },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/evidence" }
    }
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "required": ["document_id", "quote", "direct_or_inferred"],
      "properties": {
        "document_id": { "type": "string" },
        "section_title": { "type": ["string", "null"] },
        "page_number": { "type": ["integer", "null"] },
        "quote": { "type": "string" },
        "direct_or_inferred": { "type": "string", "enum": ["direct", "inferred", "contextual"] }
      }
    }
  }
}

