{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openbioforge.example/schemas/candidate_relation.schema.json",
  "title": "CandidateRelation",
  "type": "object",
  "required": ["subject_label", "predicate", "object_label", "confidence_score", "evidence"],
  "properties": {
    "subject_label": { "type": "string" },
    "predicate": {
      "type": "string",
      "enum": ["is_a", "part_of", "has_part", "regulates", "located_in", "occurs_in", "derives_from", "related_to"]
    },
    "object_label": { "type": "string" },
    "direct_or_inferred": { "type": "string", "enum": ["direct", "inferred", "contextual"] },
    "confidence_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "uncertainty_note": { "type": ["string", "null"] },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["document_id", "quote"],
        "properties": {
          "document_id": { "type": "string" },
          "quote": { "type": "string" },
          "section_title": { "type": ["string", "null"] },
          "page_number": { "type": ["integer", "null"] }
        }
      }
    }
  }
}

